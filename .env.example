# =============================================================================
# Thrifti Storefront — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Shopify Storefront API (REQUIRED)
# ---------------------------------------------------------------------------
# Your Shopify store domain (e.g. your-store.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Public Storefront API access token
# Shopify Admin → Settings → Apps and sales channels → Develop apps → Storefront API
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# ---------------------------------------------------------------------------
# Database (REQUIRED for wishlist and user features)
# ---------------------------------------------------------------------------
# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@host:3306/dbname

# ---------------------------------------------------------------------------
# Session Security (REQUIRED)
# ---------------------------------------------------------------------------
# Long random string used to sign session cookies
# Generate with: openssl rand -base64 64
JWT_SECRET=your-long-random-secret-here

# ---------------------------------------------------------------------------
# Manus OAuth (Optional — for admin/dashboard auth)
# ---------------------------------------------------------------------------
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://login.manus.im
OWNER_OPEN_ID=your-manus-open-id

# ---------------------------------------------------------------------------
# Manus Forge API (Optional — for LLM, storage, notifications)
# ---------------------------------------------------------------------------
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ---------------------------------------------------------------------------
# Analytics (Optional — Umami analytics)
# ---------------------------------------------------------------------------
# VITE_ANALYTICS_ENDPOINT=https://analytics.yourdomain.com
# VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Port to listen on (default: 3000)
PORT=3000
NODE_ENV=production
